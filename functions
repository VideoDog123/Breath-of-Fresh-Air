def interface(choices):
# receives a list of strings and displays them, then asks for the user to choose an option and sends that string back
# due to how often the player is asked for input this function handles all player input for brevity of the code's syntax
# error checking performed in the logic of rooms, rooms only accept certain numbers as strings, always '1', '2', '3', or '4'
    count = 0
    print()
    for option in choices:
        count += 1
        print(f"{count}. {option}")
    choice = input("Choose: ")
    print()
    return choice


